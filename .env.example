# ─────────────────────────────────────────────────────────────────────────
# Brimble Deployment Pipeline — Environment Variables
#
# Copy this file to .env and fill in values as needed.
# All variables have sensible defaults that work with docker compose up.
# You do NOT need to create any external accounts to run this locally.
# ─────────────────────────────────────────────────────────────────────────

# ── Optional: private repo support ───────────────────────────────────────
# Set GITHUB_TOKEN to clone private GitHub repos (classic PAT with `repo` scope)
# Set GITLAB_TOKEN for private GitLab repos (personal access token with `read_repository`)
# Leave blank to use public repos only (default for demo).
GITHUB_TOKEN=
GITLAB_TOKEN=

# ── Internal service config (defaults work out of the box) ───────────────
# Starting port for deployed app containers (allocated sequentially)
DEPLOY_BASE_PORT=4000
